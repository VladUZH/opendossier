# OpenDossier configuration — all optional.
# With NONE of these set, OpenDossier runs in zero-key "heuristic" mode:
# it still gathers real web sources and assembles a cited dossier, just without an LLM.
# Copy to `.env.local` and fill in to upgrade quality. Never commit your real keys.

# Which LLM provider to use for synthesis.
# One of: heuristic (default, no key) | anthropic | openai | ollama
LLM_PROVIDER=heuristic

# --- Cloud providers (opt-in upgrade) ---
# ANTHROPIC_API_KEY=sk-ant-...
# Defaults to the highest-quality model. To cut cost, set a cheaper one,
# e.g. ANTHROPIC_MODEL=claude-haiku-4-5 or claude-sonnet-4-6
# ANTHROPIC_MODEL=claude-opus-4-8

# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1   # point at any OpenAI-compatible endpoint

# --- Local provider (free, runs on your machine) ---
# Set LLM_PROVIDER=ollama and run `ollama serve`.
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# --- Web search source for gathering evidence ---
# duckduckgo (default, no key) | none
SEARCH_PROVIDER=duckduckgo
